# ytauto configuration
# Copy this to ~/.ytauto/.env or .env in your working directory
# Run `ytauto setup` for interactive configuration

# --- Required: At least one LLM provider ---
YTAUTO_ANTHROPIC_API_KEY=sk-ant-api03-...
YTAUTO_OPENAI_API_KEY=sk-...

# --- TTS: Deepgram Aura (recommended) ---
YTAUTO_DEEPGRAM_API_KEY=...

# --- Optional: ElevenLabs for premium voices ---
# YTAUTO_ELEVENLABS_API_KEY=...

# --- Defaults ---
# YTAUTO_DEFAULT_LLM_PROVIDER=claude              # claude or openai
# YTAUTO_DEFAULT_TTS_PROVIDER=deepgram             # deepgram, openai, or elevenlabs
# YTAUTO_DEFAULT_TTS_VOICE=aura-orion-en           # Deepgram: aura-orion-en, aura-asteria-en, etc.
# YTAUTO_DEFAULT_IMAGE_PROVIDER=dalle              # dalle
# YTAUTO_DEFAULT_RESOLUTION=1920x1080
# YTAUTO_DEFAULT_FPS=24
# YTAUTO_DEFAULT_IMAGE_DURATION=8
# YTAUTO_DEFAULT_MUSIC_VOLUME=0.15
